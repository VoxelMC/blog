---
export interface Props {
	url: string;
	title: string;
	date: string;
	readingTime: number;
}
const { url, title, date, readingTime } = Astro.props;
const prettyTitle = title
	.toLowerCase()
	.replaceAll(' ', 'abcda')
	.replaceAll(/[^a-z]+/g, '')
	.replaceAll('abcda', '-');
const parsedDate = new Date(date);
const month = parsedDate.toLocaleString('default', { month: 'long' });
const year = parsedDate.getFullYear();
// console.log(`${title}-${pubDate}`.toLowerCase().replaceAll(" ", ""))
---

<div
	id={prettyTitle}
	class={`mb-5 preview-card time-${month}-${year} flex flex-row last:mb-0 handheld:max-w-full`}
	data-time={`${month}-${year}`}
>
	<div class="preview-card-bar -ml-5 mr-4 w-1 bg-accentColor opacity-100">
	</div>
	<div class="handheld:max-w-full">
		<div class="w-max">
			<a
				class="preview-title-link group text-accentColor duration-200"
				data-astro-history="push"
				href={url}
			>
				<h2 class="text-xl font-medium w500:text-lg">
					{title}
				</h2>
				<span
					class="relative bottom-0.5 block h-0.5 max-w-0 bg-accentColor transition-all duration-300 group-hover:max-w-full"
				></span>
			</a>
		</div>
		<p
			class="mb3 mt-1 text-sm leading-relaxed tracking-wide w500:text-sm w500:leading-[2.2]"
		>
			<!-- <i class="ri-quill-pen-fill ri-lg"></i> {prettyDescription} -->
		</p>
		<div class="flex w-max flex-wrap items-center handheld:max-w-full">
			<div
				class="flex flex-wrap text-wrap text-sm leading-5 tracking-wide handheld:max-w-full w500:text-xs"
			>
				<i class="ri-calendar-fill ri-lg mr-1.5"></i><span
					>{parsedDate.toDateString().replace(' ', ', ')}</span
				>
				<span class="mr-1.5"
					><i class="ri-timer-line ri-lg ml-1 mr-1.5"></i>{
						Math.round(readingTime * 10) / 10
					} mins</span
				>
			</div>
		</div>
	</div>
</div>

<style>
	.preview-card-bar {
		@apply transition-opacity duration-500;
		animation-timing-function: ease;
	}
	.preview-card-bar:has(+ div .preview-title-link:hover) {
		@apply opacity-0;
	}
</style>
